{
  "_defaults": {
    "type": "text",
    "handler": "render",
    "renderWidget": true,
    "verbsWithoutPromptSuggestions": ["vector"],
    "actionMap": {
      ".inp-field": { "actionType": "autocomplete" },
      ".gen-btn": { "actionType": "generate" },
      ".drop-item": { "actionType": "setPromptValue" }
    },
    "sendSplunkAnalytics": true
  },
  "hero-marquee": {
    "selector": ".copy",
    "source": ".copy .main-copy",
    "target": ".row-supplemental a",
    "insert": "before"
  },
  "showcase-marquee": {
    "selector": ".text",
    "source": ".text",
    "target": "p:last-of-type",
    "insert": "after"
  },
  "upload-marquee": {
    "selector": ".copy",
    "source": ".copy",
    "target": ".upload-marquee-prompt-container",
    "insert": "after"
  }
}
