{
  "_defaults": {
    "renderWidget": true,
    "showSplashScreen": true,
    "extendedWidgets": ["inline-action"],
    "productTag-firefly": "FF",
    "limits-firefly": {
      "allowedFileTypes": ["image/jpeg", "image/jpg", "image/png", "image/webp"],
      "maxFileSize": 40000000,
      "maxNumFiles": 1
    },
    "splashScreenConfig": {
      "fragmentLink-firefly": "/cc-shared/fragments/products/firefly/unity/splash-page",
      "fragmentLink-firefly-dark": "/cc-shared/fragments/products/firefly/unity/splash-page-dark",
      "splashScreenParent": "body"
    },
    "sendSplunkAnalytics": true,
    "actionMap": {
      ".drop-zone": "upload",
      ".upload-action-container .action-button": "upload",
      ".ia-file-input": "upload",
      ".ia-nba-card": "connector",
      ".ia-edit-in-firefly": "connector",
      ".ia-download-btn": "download",
      ".ia-reupload-btn": "reupload"
    }
  },
  "hero-marquee": {
    "selector": ".copy",
    "source": ".copy .main-copy",
    "target": ".row-supplemental a",
    "insert": "before"
  }
}
