            { "id": "a272dae5-92bc-4838-9352-a8deffb352b0" }
          ]
        }
      },
      {
        "name": "Connector",
        "url": "{{apiEndPoint}}/asset/connector",
        "method": "POST",
        "body": {
          "targetProduct": "Photoshop",
