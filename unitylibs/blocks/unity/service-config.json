{
    "photoshop": [
      { "name": "assetUpload", "url": "{{apiEndPoint}}/asset", "method": "POST", "replaceKey": ["id","href"] },
      { "name": "acmpCheck", "url": "{{apiEndPoint}}/asset/finalize", "method": "POST", "body": { "assetId": "{{id}}", "targetProduct": "Photoshop" } },
      { "name": "Asset Upload", "url": "{{href}}", "method": "PUT", "workFlow":"getBlogData"},
      { "name": "removeBackground", "url": "{{apiEndPoint}}/providers/PhotoshopRemoveBackground", "method": "POST", "body": { "surfaceId": "Unity", "assets": [{ "id": "{{id}}" }] }, "replaceKey": ["assetId"]},
      {
        "name": "changeBackground",
        "url": "{{apiEndPoint}}/providers/PhotoshopChangeBackground",
        "method": "POST",
        "body": {
          "metadata": {
            "foregroundImageId": "{{assetId}}",
            "backgroundImageId": "{{id}}"
          },
          "assets": [
            { "id": "{{assetId}}" },
            { "id": "{{id}}" }
          ]
        }
      },
      {
        "name": "Connector",
        "url": "{{apiEndPoint}}/asset/connector",
        "method": "POST",
        "body":
          {
            "targetProduct":"Photoshop",
            "locale":"in",
            "operations":[{"name":"removeBackground"}],
            "finalAssetId":"{{assetId}}",
            "assetId":"{{id}}"
          }
      }
    ],
    "acrobat": [
      {
        "name": "Asset",
        "url": "{{apiEndPoint}}/asset",
        "method": "POST",
        "body": {
          "targetProduct": "acrobat",
          "format": "application/pdf",
          "name": "dummyfile.pdf",
          "size": 13264,
          "surfaceId": "unity"
        }
      },
      {
        "name": "Connector",
        "url": "{{apiEndPoint}}/asset/connector",
        "method": "POST",
        "body": {
          "assetId": "urn:aaid:sc:AP:4f238dfa-c9ba-3a27-975f-f30cbcb4bb85",
          "targetProduct": "acrobat",
          "payload": {
            "languageRegion": "us",
            "languageCode": "en",
            "verb": "fillsign",
            "assetMetadata": {
              "urn:aaid:sc:AP:4f238dfa-c9ba-3a27-975f-f30cbcb4bb85": {
                "name": "dummyfile.pdf",
                "size": 13264,
                "type": "application/pdf"
              }
            }
          }
        }
      },
      {
        "name": "Finalize",
        "url": "{{apiEndPoint}}/asset/finalize",
        "method": "POST",
        "body": {
          "assetId": "urn:aaid:sc:AP:4f238dfa-c9ba-3a27-975f-f30cbcb4bb85",
          "surfaceId": "unity",
          "targetProduct": "acrobat"
        }
      },
      {
        "name": "Metadata",
        "url": "{{apiEndPoint}}/asset/metadata?id=urn%3Aaaid%3Asc%3AAP%3A4f238dfa-c9ba-3a27-975f-f30cbcb4bb85",
        "method": "GET"
      }
    ],
    "express": [
      {
        "name": "Connector",
        "url": "{{apiEndPoint}}/asset/connector",
        "method": "POST",
        "body": {
          "targetProduct": "Express",
          "query": "Soccer tournament finals poster"
        }
      },
      {
        "name": "AutoComplete",
        "url": "{{apiEndPoint}}/providers/AutoComplete",
        "method": "POST",
        "body": {
          "query": "hello",
          "maxResults": 12
        }
      }
    ]
}
  
  